# Exalm configuration — copy to .env (which is gitignored) and fill in.
#
# For FREE local development (no API key needed) → use Ollama section below.
# For production quality output                  → use Claude section below.

# ─── LLM PROVIDER ────────────────────────────────────────────────────────────
# Choose one: "ollama" (free, local) | "claude" (paid, best quality) | "openai"
EXALM_LLM_PROVIDER=ollama

# ─── OLLAMA (free, no account needed) ────────────────────────────────────────
# 1. Install:   https://ollama.ai  (one-click installer, Mac/Linux/Windows)
# 2. Start:     ollama serve
# 3. Pull:      ollama pull llama3.1:8b   (5GB, best quality)
#               ollama pull llama3.2:3b   (2GB, faster, lower quality)
#               ollama pull mistral:7b    (4GB, good alternative)
EXALM_LLM_MODEL=llama3.1:8b
EXALM_OLLAMA_URL=http://localhost:11434

# ─── CLAUDE API (best output quality) ────────────────────────────────────────
# Get key: https://console.anthropic.com -> API Keys -> Create Key
# Set a spending limit: console.anthropic.com -> Settings -> Billing
#
# EXALM_LLM_PROVIDER=claude
# ANTHROPIC_API_KEY=sk-ant-EXAMPLE-EXAMPLE
# EXALM_LLM_MODEL=claude-haiku-4-5-20251001   # cheapest
# EXALM_LLM_MODEL=claude-sonnet-4-6           # best quality

# ─── OUTPUT ──────────────────────────────────────────────────────────────────
# EXALM_OUTPUT=markdown
